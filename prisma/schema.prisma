generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String   @id @default(cuid())
  slug         String   @unique
  businessName String
  tagline      String?
  lipaNumber   String
  lipaLabel    String   @default("Lipa Number")
  repairNumber String?
  agentCode    String?
  accentColor  String   @default("#f5c518")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
