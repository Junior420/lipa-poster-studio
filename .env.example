# Postgres connection string (Vercel Postgres / Neon / Supabase — any Postgres works)
DATABASE_URL="postgres://user:password@host:5432/dbname"

# PIN used to unlock /admin (pick something only you know, 4-8 digits or a passphrase)
ADMIN_PIN="change-me"

# Random secret used to sign the admin session cookie — generate with: openssl rand -hex 32
SESSION_SECRET="change-me-too"

# Public base URL of the deployed app (used to build absolute links for sharing)
NEXT_PUBLIC_BASE_URL="https://lipa-poster-studio.vercel.app"
